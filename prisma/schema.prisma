generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model OperatorSession {
  id            String            @id @default(cuid())
  ownerId       String
  title         String
  archivedAt    DateTime?
  lastMessageAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  messages      OperatorMessage[]
  memories      OperatorMemory[]

  @@index([ownerId, archivedAt, lastMessageAt])
}

model OperatorMessage {
  id             String           @id @default(cuid())
  ownerId        String
  sessionId      String?
  role           MessageRole
  content        String
  citations      Json?
  meta           Json?
  createdAt      DateTime         @default(now())
  session        OperatorSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceMemories OperatorMemory[]

  @@index([ownerId, sessionId, createdAt])
}

model OperatorMemory {
  id              String            @id @default(cuid())
  ownerId         String
  sessionId       String?
  sourceMessageId String?
  kind            AgentMemoryKind
  title           String
  content         String
  contentHash     String
  status          AgentMemoryStatus @default(ACTIVE)
  archivedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  session         OperatorSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sourceMessage   OperatorMessage?  @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)

  @@unique([ownerId, contentHash])
  @@index([ownerId, status, updatedAt])
  @@index([sessionId])
  @@index([sourceMessageId])
}

model OperatorUsageLog {
  id             String   @id @default(cuid())
  ownerId        String
  scope          String
  model          String?
  modelChannelId String?
  tokensIn       Int      @default(0)
  tokensOut      Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([ownerId, createdAt])
}

model InternalKnowledgeDocument {
  id                  String                  @id @default(cuid())
  slug                String                  @unique
  title               String
  summary             String
  body                String
  tags                Json?
  status              InternalKnowledgeStatus @default(DRAFT)
  sourceType          String                  @default("manual")
  safetyNotes         String?
  contentHash         String
  lastSyncedAt        DateTime?
  createdByMemberId   String?
  createdByOperatorId String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
}

model InternalKnowledgeSyncRun {
  id            String                      @id @default(cuid())
  status        InternalKnowledgeSyncStatus @default(STARTED)
  documentCount Int                         @default(0)
  chunkCount    Int                         @default(0)
  issueCount    Int                         @default(0)
  startedAt     DateTime                    @default(now())
  finishedAt    DateTime?
  diagnostic    Json?
}

model ContentDraft {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  column          String
  tag             String
  detail          String
  readTime        String             @default("8 min")
  bodyJson        Json
  knowledgePoints Json?
  projectIds      Json?
  status          ContentDraftStatus @default(DRAFT)
  visibility      ContentVisibility  @default(HIDDEN)
  aiAssistance    String             @default("none")
  createdBy       String?
  updatedBy       String?
  publishedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  reviews         ContentReview[]
  publishExports  PublishExport[]
  aiDailyIssues   AiDailyIssue[]
}

model ContentReview {
  id             String              @id @default(cuid())
  draftId        String
  status         ContentReviewStatus @default(PENDING)
  checklistJson  Json
  notes          String              @default("")
  reviewedBy     String?
  reviewedAt     DateTime            @default(now())
  draft          ContentDraft        @relation(fields: [draftId], references: [id], onDelete: Cascade)
  publishExports PublishExport[]
}

model PublishExport {
  id                String         @id @default(cuid())
  draftId           String
  reviewId          String?
  draftUpdatedAt    DateTime?
  target            String
  exportedFilesJson Json
  checksJson        Json?
  exportedBy        String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  draft             ContentDraft   @relation(fields: [draftId], references: [id], onDelete: Cascade)
  review            ContentReview? @relation(fields: [reviewId], references: [id], onDelete: SetNull)

  @@unique([draftId, draftUpdatedAt])
}

model SourceItem {
  id                      String               @id @default(cuid())
  title                   String
  url                     String
  canonicalUrl            String?
  canonicalKey            String?              @unique
  canonicalizationVersion Int                  @default(1)
  contentHash             String?
  titleFingerprint        String?
  publisherDomain         String?
  sourceName              String
  sourceTier              String
  language                String               @default("zh")
  publishedAt             DateTime?
  capturedAt              DateTime             @default(now())
  lastObservedAt          DateTime?
  rawExcerpt              String?
  summary                 String               @default("")
  tagsJson                Json?
  riskFlagsJson           Json?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  issueSources            AiDailyIssueSource[]
  candidates              AiDailyCandidate[]   @relation("AiDailyCandidatePromotedSource")

  @@index([publisherDomain, publishedAt])
  @@index([contentHash])
  @@index([titleFingerprint])
}

model AiDailyIssue {
  id                        String                     @id @default(cuid())
  date                      String                     @unique
  editionDate               DateTime?                  @unique @db.Date
  title                     String
  status                    AiDailyIssueStatus         @default(SOURCE_COLLECTED)
  workflowState             AiDailyEditorialState      @default(COLLECTING)
  sourceIdsJson             Json
  briefJson                 Json?
  selectionVersion          Int                        @default(0)
  selectedEvidenceVersion   Int                        @default(0)
  generatedRevisionSequence Int                        @default(0)
  latestGeneratedRevisionId String?                    @unique
  newEvidenceAvailable      Boolean                    @default(false)
  deployedPublicAt          DateTime?
  draftId                   String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  draft                     ContentDraft?              @relation(fields: [draftId], references: [id], onDelete: SetNull)
  latestGeneratedRevision   AiDailyGeneratedRevision?  @relation("AiDailyIssueLatestGeneratedRevision", fields: [latestGeneratedRevisionId], references: [id], onDelete: SetNull)
  sources                   AiDailyIssueSource[]
  runs                      AiDailyRun[]
  generatedRevisions        AiDailyGeneratedRevision[] @relation("AiDailyIssueGeneratedRevisions")

  @@index([status, date])
  @@index([workflowState, editionDate])
  @@index([draftId])
}

model AiDailySourceFeed {
  id                  String                    @id @default(cuid())
  name                String
  kind                AiDailySourceFeedKind
  url                 String
  canonicalKey        String
  locale              String                    @default("zh")
  tier                String
  topicsJson          Json?
  enabled             Boolean                   @default(true)
  intervalMinutes     Int                       @default(60)
  lookbackMinutes     Int                       @default(120)
  officialDomain      String?
  etag                String?
  lastModified        String?
  lastAttemptedAt     DateTime?
  lastCollectedAt     DateTime?
  lastSuccessfulAt    DateTime?
  nextCollectAt       DateTime?
  consecutiveFailures Int                       @default(0)
  healthStatus        AiDailySourceHealthStatus @default(UNKNOWN)
  lastLagMs           Int?
  lastErrorCategory   String?
  lastErrorJson       Json?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  candidates          AiDailyCandidate[]
  workItems           AiDailyWorkItem[]

  @@unique([kind, canonicalKey])
  @@index([enabled, nextCollectAt])
  @@index([tier, enabled, lastSuccessfulAt])
}

model AiDailyRun {
  id                    String                        @id @default(cuid())
  issueId               String?
  editionDate           DateTime                      @db.Date
  profile               AiDailyProfile
  trigger               AiDailyRunTrigger
  attemptNumber         Int
  eventSequence         Int                           @default(0)
  status                AiDailyRunStatus              @default(QUEUED)
  currentStage          AiDailyRunStage?
  configVersion         String
  startedAt             DateTime?
  finishedAt            DateTime?
  newestPublishedAt     DateTime?
  lastTier1CollectedAt  DateTime?
  lastCollectedAt       DateTime?
  lastDiscoveredAt      DateTime?
  lastFetchedAt         DateTime?
  pipelineFreshnessAt   DateTime?
  endToEndLagMs         Int?
  countersJson          Json?
  finalErrorCategory    String?
  finalErrorJson        Json?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  issue                 AiDailyIssue?                 @relation(fields: [issueId], references: [id], onDelete: SetNull)
  events                AiDailyRunEvent[]
  generationCheckpoints AiDailyGenerationCheckpoint[]
  workItems             AiDailyWorkItem[]
  workAttempts          AiDailyWorkAttempt[]
  candidates            AiDailyCandidate[]
  clusters              AiDailyCluster[]

  @@unique([editionDate, attemptNumber])
  @@index([editionDate, status])
  @@index([status, currentStage, createdAt])
  @@index([issueId])
}

model AiDailyRunEvent {
  id            String           @id @default(cuid())
  runId         String
  sequence      Int
  stage         AiDailyRunStage?
  kind          String
  outcome       String
  providerRole  String?
  attemptNumber Int?
  errorCategory String?
  durationMs    Int?
  metadataJson  Json?
  createdAt     DateTime         @default(now())
  run           AiDailyRun       @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@index([runId, createdAt])
}

model AiDailyGenerationCheckpoint {
  id            String          @id @default(cuid())
  runId         String
  stage         AiDailyRunStage
  payloadJson   Json
  payloadHash   String
  schemaVersion String
  createdAt     DateTime        @default(now())
  run           AiDailyRun      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stage])
  @@index([runId, createdAt])
}

model AiDailyWorkItem {
  id                     String               @id @default(cuid())
  kind                   AiDailyWorkKind
  editionDate            DateTime?            @db.Date
  runId                  String?
  sourceFeedId           String?
  idempotencyKey         String               @unique
  priority               Int                  @default(0)
  status                 AiDailyWorkStatus    @default(PENDING)
  availableAt            DateTime             @default(now())
  leaseOwner             String?
  leaseToken             String?
  leaseExpiresAt         DateTime?
  attemptCount           Int                  @default(0)
  maxAttempts            Int                  @default(3)
  continuationCursorJson Json?
  deadlineAt             DateTime?
  freshnessTargetAt      DateTime?
  completedAt            DateTime?
  lastErrorCategory      String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  run                    AiDailyRun?          @relation(fields: [runId], references: [id], onDelete: SetNull)
  sourceFeed             AiDailySourceFeed?   @relation(fields: [sourceFeedId], references: [id], onDelete: SetNull)
  attempts               AiDailyWorkAttempt[]

  @@index([status, availableAt, priority])
  @@index([leaseExpiresAt])
  @@index([editionDate, kind, status])
  @@index([runId])
  @@index([sourceFeedId])
}

model AiDailyWorkAttempt {
  id            String                    @id @default(cuid())
  workItemId    String
  attemptNumber Int
  runId         String?
  leaseToken    String
  startedAt     DateTime                  @default(now())
  finishedAt    DateTime?
  outcome       AiDailyWorkAttemptOutcome @default(RUNNING)
  errorCategory String?
  durationMs    Int?
  metadataJson  Json?
  workItem      AiDailyWorkItem           @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  run           AiDailyRun?               @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([workItemId, attemptNumber])
  @@index([workItemId, startedAt])
  @@index([runId])
}

model AiDailyCandidate {
  id                     String                         @id @default(cuid())
  runId                  String
  sourceFeedId           String?
  providerKind           String
  providerRole           String                         @default("stable")
  discoveryQueryGroup    String?
  leadOnly               Boolean                        @default(false)
  sourceExternalId       String?
  observationKey         String                         @default("primary")
  observedAt             DateTime                       @default(now())
  originalUrl            String
  normalizedUrl          String
  canonicalUrl           String
  canonicalKey           String
  title                  String
  publisher              String
  publisherDomain        String
  publishedAt            DateTime?
  locale                 String                         @default("zh")
  sourceTier             String
  titleFingerprint       String?
  contentHash            String?
  fetchStatus            AiDailyCandidateFetchStatus    @default(DISCOVERED)
  evidenceStatus         AiDailyCandidateEvidenceStatus @default(UNCHECKED)
  fetchAttemptCount      Int                            @default(0)
  lastErrorCategory      String?
  evidenceVersion        Int                            @default(0)
  currentEvidenceId      String?                        @unique
  fetchedAt              DateTime?
  evidenceExcerpt        String?
  evidenceExpiresAt      DateTime?
  duplicateOfCandidateId String?
  clusterId              String?
  selectionState         AiDailyCandidateSelectionState @default(CANDIDATE)
  scoreTotal             Float?
  scoreJson              Json?
  sourceItemId           String?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  run                    AiDailyRun                     @relation(fields: [runId], references: [id], onDelete: Cascade)
  sourceFeed             AiDailySourceFeed?             @relation(fields: [sourceFeedId], references: [id], onDelete: SetNull)
  sourceItem             SourceItem?                    @relation("AiDailyCandidatePromotedSource", fields: [sourceItemId], references: [id], onDelete: SetNull)
  currentEvidence        AiDailyEvidenceDocument?       @relation("AiDailyCandidateCurrentEvidence", fields: [currentEvidenceId], references: [id], onDelete: SetNull)
  evidenceDocuments      AiDailyEvidenceDocument[]      @relation("AiDailyCandidateEvidenceHistory")
  cluster                AiDailyCluster?                @relation("AiDailyClusterMembers", fields: [clusterId], references: [id], onDelete: SetNull)
  duplicateOf            AiDailyCandidate?              @relation("AiDailyCandidateDuplicates", fields: [duplicateOfCandidateId], references: [id], onDelete: SetNull)
  duplicates             AiDailyCandidate[]             @relation("AiDailyCandidateDuplicates")
  representedClusters    AiDailyCluster[]               @relation("AiDailyClusterRepresentative")

  @@unique([runId, canonicalKey, observationKey])
  @@index([canonicalKey])
  @@index([runId, selectionState, scoreTotal])
  @@index([evidenceExpiresAt])
  @@index([currentEvidenceId])
  @@index([sourceItemId])
  @@index([sourceFeedId])
  @@index([clusterId])
  @@index([duplicateOfCandidateId])
}

model AiDailyEvidenceDocument {
  id                  String                          @id @default(cuid())
  candidateId         String
  version             Int
  extractionMethod    AiDailyEvidenceExtractionMethod
  originalUrl         String
  canonicalUrl        String
  title               String
  publisher           String
  author              String?
  publishedAt         DateTime?
  fetchedAt           DateTime
  locale              String                          @default("zh")
  contentType         String
  contentHash         String
  headingsJson        Json
  normalizedText      String
  excerpt             String
  normalizedBytes     Int
  status              AiDailyEvidenceDocumentStatus
  errorCategory       String?
  expiresAt           DateTime
  createdAt           DateTime                        @default(now())
  candidate           AiDailyCandidate                @relation("AiDailyCandidateEvidenceHistory", fields: [candidateId], references: [id], onDelete: Cascade)
  currentForCandidate AiDailyCandidate?               @relation("AiDailyCandidateCurrentEvidence")

  @@unique([candidateId, version])
  @@index([candidateId, fetchedAt])
  @@index([contentHash])
  @@index([expiresAt])
}

model AiDailyCluster {
  id                        String                    @id @default(cuid())
  runId                     String
  stableIdentityKey         String
  representativeCandidateId String?
  groupingReason            String
  topic                     String
  corroborationCount        Int                       @default(0)
  scoreTotal                Float?
  scoreJson                 Json?
  rank                      Int?
  selectedAt                DateTime?
  editorState               AiDailyClusterEditorState @default(AUTO)
  editorReason              String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  run                       AiDailyRun                @relation(fields: [runId], references: [id], onDelete: Cascade)
  representativeCandidate   AiDailyCandidate?         @relation("AiDailyClusterRepresentative", fields: [representativeCandidateId], references: [id], onDelete: SetNull)
  candidates                AiDailyCandidate[]        @relation("AiDailyClusterMembers")

  @@unique([runId, stableIdentityKey])
  @@index([runId, rank])
  @@index([representativeCandidateId])
}

model AiDailyIssueSource {
  id               String       @id @default(cuid())
  issueId          String
  sourceItemId     String
  selectionVersion Int
  position         Int
  selectedBy       String
  selectionReason  String?
  evidenceVersion  Int          @default(0)
  createdAt        DateTime     @default(now())
  issue            AiDailyIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  sourceItem       SourceItem   @relation(fields: [sourceItemId], references: [id], onDelete: Restrict)

  @@unique([issueId, selectionVersion, sourceItemId])
  @@unique([issueId, selectionVersion, position])
  @@index([issueId, selectionVersion, position])
  @@index([sourceItemId])
}

model AiDailyGeneratedRevision {
  id                     String                           @id @default(cuid())
  generationKey          String?                          @unique
  issueId                String
  revisionNumber         Int
  selectionVersion       Int
  evidenceVersion        Int
  contentJson            Json
  sourceBindingsJson     Json
  citationSnapshotsJson  Json
  citationSchemaVersion  Int                              @default(2)
  promptVersion          String
  schemaVersion          String
  modelRole              String
  modelIdentifier        String
  observedDraftUpdatedAt DateTime?
  projectionDraftId      String?
  applyState             AiDailyGeneratedApplyState       @default(PENDING)
  validationStatus       AiDailyGeneratedValidationStatus
  validationFindingsJson Json?
  createdBy              String
  createdAt              DateTime                         @default(now())
  appliedAt              DateTime?
  issue                  AiDailyIssue                     @relation("AiDailyIssueGeneratedRevisions", fields: [issueId], references: [id], onDelete: Cascade)
  latestForIssue         AiDailyIssue?                    @relation("AiDailyIssueLatestGeneratedRevision")
  flashRevisions         AiDailyFlashRevision[]

  @@unique([issueId, revisionNumber])
  @@index([issueId, validationStatus, createdAt])
}

model AiDailyFlashItem {
  id                        String                     @id @default(cuid())
  publicId                  String                     @unique
  stableEventKey            String                     @unique
  sourceClusterIdentity     String
  lifecycleState            AiDailyFlashLifecycleState @default(ACTIVE)
  currentApprovedRevisionId String?                    @unique
  revisionSequence          Int                        @default(0)
  publicRevision            Int                        @default(0)
  createdAt                 DateTime                   @default(now())
  lastApprovedAt            DateTime?
  withdrawnAt               DateTime?
  retentionUntil            DateTime?
  projectionUpdatedAt       DateTime?
  revisions                 AiDailyFlashRevision[]     @relation("AiDailyFlashItemRevisions")
  currentApprovedRevision   AiDailyFlashRevision?      @relation("AiDailyFlashCurrentApprovedRevision", fields: [currentApprovedRevisionId], references: [id], onDelete: SetNull)
  approvalActions           AiDailyApprovalAction[]

  @@index([lifecycleState, lastApprovedAt])
  @@index([retentionUntil])
}

model AiDailyFlashRevision {
  id                    String                     @id @default(cuid())
  flashItemId           String
  revisionNumber        Int
  generatedRevisionId   String?
  selectionVersion      Int
  evidenceVersion       Int
  title                 String
  factSummary           String
  whyItMatters          String
  uncertainty           String?
  correctionState       String                     @default("none")
  correctedAt           DateTime?
  citationSnapshotsJson Json
  citationSchemaVersion Int                        @default(2)
  status                AiDailyFlashRevisionStatus @default(DRAFT)
  editor                String?
  approvedAt            DateTime?
  supersededRevisionId  String?
  createdAt             DateTime                   @default(now())
  flashItem             AiDailyFlashItem           @relation("AiDailyFlashItemRevisions", fields: [flashItemId], references: [id], onDelete: Cascade)
  currentForItem        AiDailyFlashItem?          @relation("AiDailyFlashCurrentApprovedRevision")
  generatedRevision     AiDailyGeneratedRevision?  @relation(fields: [generatedRevisionId], references: [id], onDelete: SetNull)
  supersededRevision    AiDailyFlashRevision?      @relation("AiDailyFlashSupersession", fields: [supersededRevisionId], references: [id], onDelete: SetNull)
  supersedingRevisions  AiDailyFlashRevision[]     @relation("AiDailyFlashSupersession")
  approvalActions       AiDailyApprovalAction[]

  @@unique([flashItemId, revisionNumber])
  @@index([flashItemId, status, createdAt])
  @@index([generatedRevisionId])
  @@index([supersededRevisionId])
}

model AiDailyApprovalAction {
  id                     String                    @id @default(cuid())
  flashItemId            String
  flashRevisionId        String?
  action                 AiDailyApprovalActionKind
  actor                  String
  reason                 String?
  observedRevisionNumber Int?
  metadataJson           Json?
  createdAt              DateTime                  @default(now())
  flashItem              AiDailyFlashItem          @relation(fields: [flashItemId], references: [id], onDelete: Restrict)
  flashRevision          AiDailyFlashRevision?     @relation(fields: [flashRevisionId], references: [id], onDelete: Restrict)

  @@index([flashItemId, createdAt, id])
  @@index([flashRevisionId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AgentMemoryKind {
  PREFERENCE
  PROJECT
  WORKFLOW
  CONTEXT
}

enum AgentMemoryStatus {
  ACTIVE
  ARCHIVED
}

enum InternalKnowledgeStatus {
  DRAFT
  REVIEWED
  ACTIVE
  ARCHIVED
}

enum InternalKnowledgeSyncStatus {
  STARTED
  COMPLETED
  FAILED
  SKIPPED
}

enum ContentDraftStatus {
  DRAFT
  REVIEW_NEEDED
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ContentVisibility {
  HIDDEN
  FEATURED
  ARCHIVE
}

enum ContentReviewStatus {
  PENDING
  APPROVED
  NEEDS_CHANGES
  REJECTED
}

enum AiDailyIssueStatus {
  SOURCE_COLLECTED
  EXTRACTED
  SUMMARIZED
  SYNTHESIZED
  REVIEW_NEEDED
  APPROVED
  PUBLISHED
  REJECTED
  NEEDS_MORE_EVIDENCE
}

enum AiDailyProfile {
  FIXTURE
  DEGRADED
  PRODUCTION
}

enum AiDailySourceFeedKind {
  RSS
  OFFICIAL_PAGE
  GITHUB_RELEASES
  HACKER_NEWS
  API
  SEARCH
  MANUAL
}

enum AiDailySourceHealthStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  FAILING
}

enum AiDailyRunTrigger {
  SCHEDULED
  MANUAL
  RETRY
}

enum AiDailyRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  COMPLETED_WITH_GAPS
  FAILED_CONFIG
  FAILED
  CANCELLED
}

enum AiDailyRunStage {
  COLLECT
  DISCOVER
  FETCH
  DEDUPE
  GROUP
  RANK
  PROMOTE
  EXTRACT_FACTS
  COMPOSE
  VERIFY
  VALIDATE
  DRAFT
}

enum AiDailyEditorialState {
  COLLECTING
  EVIDENCE_READY
  NEEDS_MORE_EVIDENCE
  REVIEW_NEEDED
  EXPORTED
  REJECTED
}

enum AiDailyWorkKind {
  COLLECT_FEED
  DISCOVER
  FETCH_SOURCE
  DEDUPE
  GROUP
  RANK
  PROMOTE
  EXTRACT_FACTS
  COMPOSE
  VERIFY
  VALIDATE
  DRAFT
}

enum AiDailyWorkStatus {
  PENDING
  LEASED
  RETRY_WAIT
  SUCCEEDED
  FAILED
  CANCELLED
}

enum AiDailyWorkAttemptOutcome {
  RUNNING
  SUCCEEDED
  RETRYABLE_FAILED
  FAILED
  CANCELLED
}

enum AiDailyCandidateFetchStatus {
  DISCOVERED
  FETCHED
  FAILED
  BLOCKED
}

enum AiDailyCandidateEvidenceStatus {
  UNCHECKED
  READY
  THIN
  CONFLICTING
  REJECTED
}

enum AiDailyEvidenceExtractionMethod {
  DIRECT
  FIRECRAWL
  TAVILY
}

enum AiDailyEvidenceDocumentStatus {
  READY
  THIN
  REJECTED
}

enum AiDailyCandidateSelectionState {
  CANDIDATE
  SELECTED
  REJECTED
  DUPLICATE
}

enum AiDailyClusterEditorState {
  AUTO
  PROPOSED
  ACCEPTED
  REJECTED
}

enum AiDailyGeneratedValidationStatus {
  VALID
  NEEDS_EDITOR_REVIEW
  REJECTED
}

enum AiDailyGeneratedApplyState {
  PENDING
  APPLIED
  BLOCKED
  DISCARDED
}

enum AiDailyFlashLifecycleState {
  ACTIVE
  HELD
  WITHDRAWN
}

enum AiDailyFlashRevisionStatus {
  DRAFT
  APPROVED
  REJECTED
  SUPERSEDED
}

enum AiDailyApprovalActionKind {
  SUBMITTED
  APPROVED
  REJECTED
  SUPERSEDED
  HELD
  RELEASED
  WITHDRAWN
}
