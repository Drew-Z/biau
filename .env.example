# Blog draft model channels. Keep real relay URLs and API keys in .env.local.
# Default channel used by `npm run blog:draft -- --generate`.
BLOG_DRAFT_BASE_URL=
BLOG_DRAFT_API_KEY=
BLOG_DRAFT_MODEL=
BLOG_DRAFT_PROVIDER=
BLOG_DRAFT_TEMPERATURE=0.65

# Optional profile selected with `--profile strong` or BLOG_DRAFT_PROFILE=strong.
BLOG_DRAFT_STRONG_BASE_URL=
BLOG_DRAFT_STRONG_API_KEY=
BLOG_DRAFT_STRONG_MODEL=
BLOG_DRAFT_STRONG_PROVIDER=
BLOG_DRAFT_STRONG_TEMPERATURE=0.65

# Optional profile selected with `--profile fast` or BLOG_DRAFT_PROFILE=fast.
BLOG_DRAFT_FAST_BASE_URL=
BLOG_DRAFT_FAST_API_KEY=
BLOG_DRAFT_FAST_MODEL=
BLOG_DRAFT_FAST_PROVIDER=
BLOG_DRAFT_FAST_TEMPERATURE=0.35

# Optional profile selected with `--profile review` or BLOG_DRAFT_PROFILE=review.
BLOG_DRAFT_REVIEW_BASE_URL=
BLOG_DRAFT_REVIEW_API_KEY=
BLOG_DRAFT_REVIEW_MODEL=
BLOG_DRAFT_REVIEW_PROVIDER=
BLOG_DRAFT_REVIEW_TEMPERATURE=0.2

# Legacy fallback for older blog draft scripts/configs.
GEMINI_BASE_URL=http://localhost:8317
GEMINI_API_KEY=
GEMINI_MODEL=gemini
GEMINI_TEMPERATURE=0.65
VITE_OZON_ERP_URL=https://erp.ciallobill.qzz.io
VITE_CHAT_API_BASE_URL=http://localhost:8787

PORT=8787
DATABASE_URL=postgresql://user:password@localhost:5432/biau_assistant
CORS_ORIGIN=http://localhost:5173
ADMIN_TOKEN=change-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
